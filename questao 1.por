programa {
  funcao inicio() {
    real comprimento_m, velocidade
    inteiro tempo

  //dados informados
  comprimento_m = 1.6
  tempo = 67 // 1 minuto e 7 segundos 

  velocidade = comprimento_m / tempo
  escreva("comprimento da esteira:" , comprimento_m, "metros \n")
  escreva("tempo:67 segundos(1 minuto e 7 segundos)\n")
  escreva("velocidade media: 0.02 m/s")  
  }
}
